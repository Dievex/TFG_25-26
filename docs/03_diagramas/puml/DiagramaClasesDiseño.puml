@startuml DiagramaClasesDiseno
skinparam classAttributeIconSize 0
skinparam classFontSize 11
left to right direction

package "Vista" <<boundary>> {
  class LoginView
  class DeclaracionView
  class LogView
  class AdminView
  class UsuarioCRUDView
}

package "Controlador" <<control>> {
  class AuthController {
    +login(email, password): Token
    +logout(token): void
    +verificarSesion(token): Usuario
  }
  class DeclaracionController {
    +obtenerPuestos(): List<PuestoTrabajo>
    +obtenerReferencias(): List<Referencia>
    +obtenerOrdenes(referenciaId): List<OrdenFabricacion>
  }
  class RegistroController {
    +guardarLote(registros): void
    +obtenerRegistrosPorPuesto(puestoId): List<Registro>
    +actualizarEstado(registroId, estado): void
  }
  class EnvioSAPController {
    +enviarASAP(puestoId): void
    +obtenerEstadoProcesamiento(puestoId): List<Registro>
  }
  class LogController {
    +obtenerLogs(filtros): List<LogEjecucion>
    +obtenerDetalleLogs(registroId): LogEjecucion
  }
  class AdminController {
    +verificarRolAdmin(token): boolean
  }
  class UsuarioController {
    +crearUsuario(datos): Usuario
    +obtenerUsuarios(): List<Usuario>
    +actualizarUsuario(id, datos): Usuario
    +eliminarUsuario(id): void
    +asignarRol(usuarioId, rolId): void
  }
}

package "Modelo" <<entity>> {
  class Usuario {
    +id: int
    +nombre: string
    +email: string
    +passwordHash: string
    +rolId: int
  }
  class Rol {
    +id: int
    +nombre: string
  }
  class PuestoTrabajo {
    +id: int
    +nombre: string
    +usuarioSAP: string
  }
  class Referencia {
    +id: int
    +codigo: string
    +descripcion: string
  }
  class OrdenFabricacion {
    +id: int
    +numero: string
    +cantidad: int
  }
  class Registro {
    +id: int
    +cantidad: int
    +estado: int
    +fechaCreacion: datetime
  }
  class Galia {
    +id: int
    +numeroOrden: string
    +cantidad: int
    +estado: int
    +fechaProcesado: datetime
  }
  class LogEjecucion {
    +id: int
    +tipoEvento: string
    +mensaje: string
    +fechaHora: datetime
    +exito: boolean
  }
  class ConfiguracionSAP {
    +id: int
    +usuario: string
    +ultimoCambioPassword: date
  }
  class Impresora {
    +id: int
    +nombre: string
    +ubicacion: string
  }
}


LoginView         "1" --> "1" AuthController        : usa >
DeclaracionView   "1" --> "1" DeclaracionController : usa >
DeclaracionView   "1" --> "1" RegistroController    : usa >
DeclaracionView   "1" --> "1" EnvioSAPController    : usa >
LogView           "1" --> "1" LogController         : usa >
AdminView         "1" --> "1" AdminController       : usa >
UsuarioCRUDView   "1" --> "1" UsuarioController     : usa >


AdminView o-- DeclaracionView  : contiene
AdminView o-- LogView          : contiene
AdminView o-- UsuarioCRUDView  : contiene


AuthController       --> Usuario
AuthController       --> Rol
DeclaracionController --> PuestoTrabajo
DeclaracionController --> Referencia
DeclaracionController --> OrdenFabricacion
RegistroController   --> Registro
RegistroController   --> Galia
EnvioSAPController   --> Registro
EnvioSAPController   --> ConfiguracionSAP
EnvioSAPController   --> LogEjecucion
LogController        --> LogEjecucion
LogController        --> Registro
LogController        --> Galia
AdminController      --> Usuario
AdminController      --> Rol
UsuarioController    --> Usuario
UsuarioController    --> Rol



' Generalización / herencia — Usuario tiene un Rol
Usuario  "many" --> "1" Rol               : tiene >

' Agregación — PuestoTrabajo agrega una Impresora
PuestoTrabajo o-- "1" Impresora           : asigna >

' Agregación — PuestoTrabajo tiene ConfiguracionSAP
PuestoTrabajo o-- "1" ConfiguracionSAP    : tiene >

' Asociación — Registro referencia a PuestoTrabajo, Referencia y OrdenFabricacion
Registro "many" --> "1" PuestoTrabajo      : pertenece a >
Registro "many" --> "1" Referencia         : usa >
Registro "many" --> "1" OrdenFabricacion   : asociada a >

' Composición — Galia es parte de un Registro (no existe sin él)
Registro *-- "many" Galia                  : genera >

' Composición — LogEjecucion es parte de un Registro
Registro *-- "many" LogEjecucion           : registra >

' Asociación — OrdenFabricacion referencia a Referencia
OrdenFabricacion "many" --> "1" Referencia : de tipo >
@enduml